{
  "name": "oversight",
  "version": "0.1.2",
  "description": "Oversight for AI agents — capture architectural constraints so agents never repeat past mistakes",
  "type": "module",
  "license": "MIT",
  "author": "Oversight Contributors",
  "homepage": "https://github.com/rudraptpsingh/oversight#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rudraptpsingh/oversight.git"
  },
  "bugs": {
    "url": "https://github.com/rudraptpsingh/oversight/issues"
  },
  "keywords": [
    "ai",
    "agents",
    "architecture",
    "decision",
    "documentation",
    "mcp",
    "model-context-protocol",
    "llm",
    "claude",
    "copilot",
    "constraints",
    "adr",
    "architecture-decision-records"
  ],
  "engines": {
    "node": ">=20.12.0"
  },
  "bin": {
    "oversight": "dist/cli/index.js",
    "oversight-mcp": "dist/mcp/server.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./db": {
      "import": "./dist/db/decisions.js",
      "types": "./dist/db/decisions.d.ts"
    },
    "./types": {
      "import": "./dist/types/index.js",
      "types": "./dist/types/index.d.ts"
    }
  },
  "files": [
    "dist/",
    "scripts/postinstall.mjs",
    "dashboard-ui/dist/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "postbuild": "node --input-type=module -e \"import{chmodSync}from'fs';['dist/cli/index.js','dist/mcp/server.js'].forEach(f=>{try{chmodSync(f,0o755)}catch{}})\"",
    "build:dashboard": "vite build",
    "build:all": "npm run build && npm run build:dashboard",
    "build:check": "tsc --noEmit",
    "prepare": "npm run build",
    "dev": "vite",
    "dev:cli": "tsx watch src/cli/index.ts",
    "dev:dashboard": "cd dashboard-ui && npm run dev",
    "start:mcp": "tsx src/mcp/server.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "benchmark": "npx tsx benchmarks/swe-bench-eval/run-eval.ts",
    "benchmark:agent-ab": "npm run build && npx tsx --no-cache benchmarks/agent-ab-test/run-benchmark.ts",
    "benchmark:agent-ab:mock": "npx tsx benchmarks/agent-ab-test/run-benchmark.ts --mock --runs 2",
    "scan": "npx tsx src/cli/index.ts scan",
    "scan:dry": "npx tsx src/cli/index.ts scan --dry-run --no-ai",
    "validate": "node scripts/validate.mjs",
    "postinstall": "node scripts/postinstall.mjs",
    "prepublishOnly": "npm run build:all && npm test",
    "lint": "tsc --noEmit",
    "precommit": "npm run build && npm test"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@google/genai": "^1.45.0",
    "@modelcontextprotocol/sdk": "^1.7.0",
    "chalk": "^5.6.2",
    "chokidar": "^4.0.3",
    "commander": "^13.1.0",
    "inquirer": "^13.3.0",
    "openai": "^6.29.0",
    "ora": "^9.3.0",
    "sql.js": "^1.14.1",
    "uuid": "^13.0.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/inquirer": "^9.0.9",
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "@types/sql.js": "^1.4.9",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^4.7.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tsx": "^4.19.3",
    "typescript": "^5.6.3",
    "vite": "^6.4.1",
    "vitest": "^4.1.0"
  }
}
